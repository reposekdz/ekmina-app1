# API Configuration
API_BASE_URL=https://api.ekimina.rw

# Payment APIs
MTN_MOMO_API_KEY=your_mtn_momo_key
AIRTEL_MONEY_API_KEY=your_airtel_money_key

# Firebase (Optional - can use google-services.json instead)
FIREBASE_API_KEY=your_firebase_api_key
FIREBASE_PROJECT_ID=ekimina-rwanda
FIREBASE_APP_ID=your_firebase_app_id

# App Configuration
APP_NAME=E-Kimina Rwanda
USSD_CODE=*700#
SUPPORT_PHONE=+250788000000
SUPPORT_EMAIL=support@ekimina.rw

# Feature Flags
ENABLE_BIOMETRIC_AUTH=true
ENABLE_DARK_MODE=true
ENABLE_OFFLINE_MODE=true
ENABLE_ANALYTICS=true

# Development
DEBUG_MODE=false
LOG_LEVEL=info
